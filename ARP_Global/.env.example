# SFTP Server Configuration
# Copy this file to .env and update with your actual credentials

# SFTP User Credentials (to be shared with Broadridge)
SFTP_USER=broadridge
SFTP_PASSWORD=ChangeThisPassword123!

# SFTP Port (default: 2222)
# Using 2222 keeps port 22 free for SSH access to the host
SFTP_PORT=2222

# Host information (update with your actual server hostname/IP)
SFTP_HOST=your-server-hostname.com
